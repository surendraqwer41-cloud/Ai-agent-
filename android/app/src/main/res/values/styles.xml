<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Normal theme applied when Flutter application loads and presents the material viewport -->
    <style name="NormalTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowActivityTransitions">true</item>
    </style>

    <!-- Theme applied as splash screen visual structure while Flutter initializes -->
    <style name="LaunchTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
</resources>
